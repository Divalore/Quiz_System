<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" styleClass="card" stylesheets="@../style/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.quizsystem.controller.CreateExamController">
   <children>
      <Label styleClass="title" text="Create New Exam" textFill="#1f2937">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      <TextField fx:id="classNameField" promptText="Class Name (e.g. Grade 10)" style="-fx-pref-width: 300; -fx-pref-height: 35;" />
      <TextField fx:id="subjectNameField" promptText="Subject Name (e.g. Mathematics)" style="-fx-pref-width: 300; -fx-pref-height: 35;" />
      <TextField fx:id="durationField" promptText="Duration in Minutes" style="-fx-pref-width: 300; -fx-pref-height: 35;" />
      
      <CheckBox fx:id="kahootModeCheckBox" text="Enable Kahoot Mode (Real-time Feedback)" style="-fx-font-weight: bold; -fx-text-fill: #374151;" />
      
      <Label fx:id="statusLabel" textFill="#10b981" />
      <Button mnemonicParsing="false" onAction="#handleSaveExam" prefWidth="300.0" styleClass="btn-primary" text="Save &amp; Generate Code" />
   </children>
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>
</VBox>