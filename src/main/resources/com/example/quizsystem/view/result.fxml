<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="800.0" prefWidth="1200.0" spacing="30.0" style="-fx-background-color: #f3f4f6;" stylesheets="@../style/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.quizsystem.controller.ResultController">
   <children>
      <VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" maxWidth="600.0" spacing="20.0" styleClass="card" VBox.vgrow="NEVER">
         <children>
            <Label text="Exam Completed!" textFill="#1f2937">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>
            <Label fx:id="messageLabel" text="Calculating...">
               <font>
                  <Font size="20.0" />
               </font>
            </Label>
            <Label fx:id="scoreLabel" text="You scored: ">
               <font>
                  <Font name="System Bold" size="24.0" />
               </font>
            </Label>
            <Label fx:id="percentageLabel" text="Percentage: ">
               <font>
                  <Font size="18.0" />
               </font>
            </Label>
            <Button mnemonicParsing="false" onAction="#goBack" prefHeight="45.0" prefWidth="250.0" styleClass="btn-primary" text="Return to Dashboard">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Button>
         </children>
      </VBox>
   </children>
</VBox>
