<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="550.0" prefWidth="700.0" style="-fx-background-color: linear-gradient(to bottom right, #4facfe 0%, #00f2fe 100%);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.quizsystem.controller.LoginController">
   <children>
      <VBox alignment="CENTER" layoutX="175.0" layoutY="85.0" prefHeight="380.0" prefWidth="350.0" spacing="20.0" styleClass="card" stylesheets="@../style/app.css">
         <children>
            <Label text="ExamQuiz" textFill="#2563eb">
               <font>
                  <Font name="System Bold" size="32.0" />
               </font>
            </Label>
            <Label text="Welcome back! Please login to your account." textFill="#6b7280" />
            <VBox spacing="5.0">
               <children>
                  <Label text="Email Address" textFill="#374151" />
                  <TextField fx:id="emailField" prefHeight="40.0" promptText="Enter your email" style="-fx-background-radius: 8; -fx-border-color: #d1d5db; -fx-border-radius: 8;" />
               </children>
            </VBox>
            <VBox spacing="5.0">
               <children>
                  <Label text="Password" textFill="#374151" />
                  <HBox alignment="CENTER_LEFT" spacing="10.0">
                     <children>
                        <StackPane HBox.hgrow="ALWAYS">
                           <children>
                              <TextField fx:id="passwordTextField" prefHeight="40.0" promptText="Enter your password" style="-fx-background-radius: 8; -fx-border-color: #d1d5db; -fx-border-radius: 8;" visible="false" />
                              <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="Enter your password" style="-fx-background-radius: 8; -fx-border-color: #d1d5db; -fx-border-radius: 8;" />
                           </children>
                        </StackPane>
                        <javafx.scene.control.CheckBox fx:id="showPasswordCheck" mnemonicParsing="false" onAction="#togglePasswordVisibility" text="👁 Show" />
                     </children>
                  </HBox>
               </children>
            </VBox>
            <Button mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" prefWidth="310.0" styleClass="btn-primary" text="Login" />
            <Label fx:id="errorLabel" textFill="#ef4444" />
            <Hyperlink onAction="#handleForgotPassword" text="Forgot Password?" textFill="#2563eb" />
         </children>
      </VBox>
   </children>
</AnchorPane>
