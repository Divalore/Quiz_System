<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" styleClass="card" stylesheets="@../style/app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.quizsystem.controller.ManageQuestionsController">
   <children>
      <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Manage Exam Questions" textFill="#1f2937" />
      <HBox alignment="CENTER" spacing="10.0">
         <children>
            <TextField fx:id="examCodeSearchField" promptText="Enter Exam Code" prefWidth="200.0" />
            <Button mnemonicParsing="false" onAction="#handleSearchExam" text="Load Exam" styleClass="btn-secondary" />
         </children>
      </HBox>
      <Label fx:id="examInfoLabel" textFill="#3b82f6" />
      
      <ListView fx:id="questionListView" prefHeight="200.0" prefWidth="500.0" />
      
      <HBox alignment="CENTER" spacing="15.0">
         <children>
            <Button mnemonicParsing="false" onAction="#handleEditSelected" styleClass="btn-primary" text="Edit Selected" prefWidth="150" />
            <Button mnemonicParsing="false" onAction="#handleDelete" styleClass="btn-secondary" text="Delete Selected" prefWidth="150" />
         </children>
      </HBox>
      
      <VBox spacing="10.0" style="-fx-border-color: #e5e7eb; -fx-border-radius: 5px; -fx-padding: 10px;">
         <children>
            <Label text="Add New Question" style="-fx-font-weight: bold;" />
            <TextField fx:id="questionContentField" promptText="Question Content" />
             <HBox spacing="15.0" alignment="CENTER_LEFT">
                <children>
                   <Label text="Question Type:" style="-fx-font-weight: bold; -fx-min-width: 100;" />
                   <ComboBox fx:id="questionTypeBox" prefWidth="180.0" onAction="#handleTypeChange" style="-fx-pref-height: 35;" />
                   <Label text="Points:" style="-fx-font-weight: bold; -fx-min-width: 60;" />
                   <TextField fx:id="pointsField" promptText="1" prefWidth="80.0" style="-fx-pref-height: 35;" />
                </children>
             </HBox>
            
            <VBox fx:id="mcqFieldsContainer" spacing="10.0">
               <children>
                  <HBox spacing="10.0">
                     <children>
                        <TextField fx:id="optionAField" promptText="Option A" HBox.hgrow="ALWAYS" />
                        <TextField fx:id="optionBField" promptText="Option B" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  <HBox spacing="10.0">
                     <children>
                        <TextField fx:id="optionCField" promptText="Option C" HBox.hgrow="ALWAYS" />
                        <TextField fx:id="optionDField" promptText="Option D" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  <ComboBox fx:id="correctAnswerBox" promptText="Select Correct Answer" prefWidth="200.0" />
               </children>
            </VBox>
            <Button mnemonicParsing="false" onAction="#handleAddQuestion" styleClass="btn-primary" text="Save Question" />
            <Label fx:id="addStatusLabel" />
         </children>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>